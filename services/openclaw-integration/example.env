DATABASE_URL=postgresql://user:password@host/db?sslmode=require
OPENCLAW_BASE_URL=https://api.cdopenclaw.com
OPENCLAW_API_KEY=replace_me
INTEGRATION_API_KEY=replace_me
APP_ENV=development
LOG_LEVEL=info

# Governance (see docs/governance-backend.md)
# TEST_EXECUTE_ENABLED=true — allow POST /test/execute in production (default: off in prod)
# TASK_CONTINUE_ENABLED=false — disable POST /task/{id}/continue
# POLICY_VERSION_EXECUTION_OVERRIDE=1.0.0 — force execution-time policy version (staging/CI; can block with RE_EVALUATION_REQUIRED)

# UATO admissibility (optional; default HIGH/HIGH preserves legacy behavior when body omits uato hints)
# UATO_DEFAULT_TRUST_LEVEL=HIGH
# UATO_DEFAULT_AUTHORITY_LEVEL=HIGH

# OpenAI Vessel + Invariant-C + Substrate Adapter (opt-in flow)
# OPENAI_FLOW_ENABLED=false
# OPENAI_API_KEY=replace_me
# OPENAI_PLAN_MODEL=gpt-5.4-mini
# OPENAI_PLAN_TIMEOUT_SECONDS=30
# OPENAI_PLAN_MAX_RETRIES=1
